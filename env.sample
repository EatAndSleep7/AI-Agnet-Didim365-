API_V1_PREFIX = "/api/v1"

CORS_ORIGINS = ["http://localhost:3000", "http://localhost:5173"]
# 필수 설정
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Elasticsearch 설정
ES__URL=https://elasticsearch-edu.didim365.app
ES__USER=elastic
ES__PASSWORD=your_es_password
ES__INDEX=bestbanker-2025

# Opik 설정 (선택사항)
# Self-hosted 사용 시: OPIK__URL_OVERRIDE 설정
# OPIK__URL_OVERRIDE=http://localhost:5173/api
# Cloud 사용 시: API_KEY, WORKSPACE 설정
# OPIK__API_KEY=your_opik_api_key
# OPIK__WORKSPACE=your_workspace
# OPIK__PROJECT=your_project_name